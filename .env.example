# Copy to .env and fill in. Never commit .env.

GRAVITY_JWT=eyJhbGciOiJIUzI1NiIs...
GRAVITY_ID=275008
GRAVITY_CID=269604
GRAVITY_EMAIL=5b9b1f62bb85e17929c74ab6dbf61d09

# SQLite path — relative paths are resolved from project root (not CWD)
DB_PATH=./data/tracker.db

# Asia/Shanghai recommended for schedule
TZ=Asia/Shanghai

# YYB 应用宝（采集三榜；境外/限速时可设代理）
YYB_GUID=91b8f8b5-de10-46a4-b128-81f31fc100ae
# YYB_PROXY_URL=http://127.0.0.1:7890

# OpenAI 兼容接口（官方 ChatGPT、第三方转发、DeepSeek 等；用于描述兜底 + 分类）
# pip: openai — 使用 Chat Completions
# OPENAI_API_KEY=
# 官方示例：https://api.openai.com/v1 ；第三方以文档为准，一般需带 /v1
# OPENAI_BASE_URL=https://api.openai.com/v1
# 模型名与平台一致，如 gpt-4o-mini、gpt-4o、或第三方给出的 ID
# OPENAI_MODEL=gpt-4o-mini
#
# 批量洞察推断（POST /api/insight/infer-batch）与分类共用上述 OPENAI_* 或 DEEPSEEK_*
# 洞察要求模型按提示输出「单个 JSON 数组」；若常返回空数组或非 JSON，请换模型或检查网关是否改写 content
# 若仍使用旧变量名也可读取（兼容）：DEEPSEEK_API_KEY / DEEPSEEK_BASE_URL / DEEPSEEK_MODEL
#
# --- 本地 Qwen / Ollama 等（OpenAI 兼容，优先于上方云端）---
# 同时配置 OPENAI_LOCAL_BASE_URL + OPENAI_LOCAL_MODEL 时：先请求本地，连接失败/5xx/429 等再回退到 OPENAI_*。
# Ollama 示例：OPENAI_LOCAL_BASE_URL=http://127.0.0.1:11434/v1 ，模型名与 ollama list 一致。
# OPENAI_LOCAL_API_KEY 可省略（内部用占位 key）；vLLM 等若需鉴权再填写。
# OPENAI_LOCAL_BASE_URL=http://127.0.0.1:11434/v1
# OPENAI_LOCAL_MODEL=qwen3:14b
# OPENAI_LOCAL_API_KEY=

# 仅本地开发：允许 scripts/seed_insight_demo.py 写入演示数据（生产勿设为 1）
# MINIGAME_ALLOW_DEMO_SEED=1

# --- 同事访问本机看板（与 .env 无关，见 start-backend.ps1）---
# 脚本默认 uvicorn --host 0.0.0.0。发链接：http://<你电脑IPv4>:8000/minigame-tracker/?platform=wx
# ipconfig 查看 IPv4；对方须与你同局域网。Windows 需放行入站 TCP 8000。
# 仅本机访问：在 PowerShell 先执行 $env:UVICORN_HOST="127.0.0.1" 再 .\start-backend.ps1

# --- 前 50 洞察自动化与看板 UI（hub 本机 / 同事看板）---
# 同事只看数据、不点「一键补全前50」：设为 0，前端 GET /api/config 后隐藏榜单页批量区（仍可用详情里 50 名外的手动 AI）
# SHOW_TOP50_BULK_BUTTON=0
#
# 在跑采集+后端的 hub 机器上：每日引力/YYB 采集结束后，后台线程自动对 wx、dy（引力后）与 yyb（YYB 后）跑 top50 洞察（与 insight_gap_only 一致，仅补缺）
# 需配置 OPENAI_*（或仅 OPENAI_LOCAL_*）；耗时可能数分钟，不阻塞采集主流程
# AUTO_TOP50_INSIGHT_AFTER_COLLECT=1
#
# 手动补跑三平台前50（与自动逻辑相同）：在项目根执行  python scripts/run_top50_insight.py
